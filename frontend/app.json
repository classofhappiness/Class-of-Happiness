{
  "expo": {
    "name": "Class of Happiness",
    "slug": "class-of-happiness",
    "version": "1.0.7",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "classofhappiness",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.classofhappiness.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Take photos for student avatars and family check-ins",
        "NSPhotoLibraryUsageDescription": "Upload photos for student avatars, strategies, and family check-ins",
        "UIViewControllerBasedStatusBarAppearance": false,
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryAddUsageDescription": "Save photos from Class of Happiness"
      },
      "buildNumber": "8"
    },
    "android": {
      "package": "com.classofhappiness.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo_coh.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo_coh.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos for avatars and strategies.",
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera for profile photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "671f7f5a-f522-4a75-8d37-5d7113e2c5bb"
      }
    },
    "owner": "jwacarey"
  }
}