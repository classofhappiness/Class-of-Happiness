        writer = csv.DictWriter(output, fieldnames=data[0].keys())
        writer.writeheader()
        writer.writerows(data)
        return {"csv": output.getvalue(), "filename": f"{type}_export.csv"}
    
    return {"data": data, "count": len(data)}
