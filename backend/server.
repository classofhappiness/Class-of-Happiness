    """Get strategies - default + custom for student, translated based on language"""
    # Get translations for the specified language
    translations = TRANSLATIONS.get(lang, TRANSLATIONS["en"])
    
    # Start with default strategies - translate them
    if zone:
        base_strategies = [s for s in DEFAULT_STRATEGIES if s["zone"] == zone]
    else:
        base_strategies = DEFAULT_STRATEGIES.copy()
    
    # Translate default strategies
    strategies = []
    for s in base_strategies:
        strategy_key = f"strategy_{s['id']}"
        desc_key = f"strategy_{s['id']}_desc"
        strategies.append({
            "id": s["id"],
            "name": translations.get(strategy_key, s["name"]),
            "description": translations.get(desc_key, s["description"]),
            "zone": s["zone"],
            "icon": s.get("icon", "star"),
            "image_type": s.get("image_type", "icon"),
        })
    
    # Add custom strategies for student (these stay as-is since user created them)
    if student_id:
        query = {"student_id": student_id, "is_active": True}
        if zone:
            query["zone"] = zone
        custom = await db.custom_strategies.find(query).to_list(100)
        for c in custom:
            strategies.append({
                "id": c["id"],
                "name": c["name"],
                "description": c["description"],
                "zone": c["zone"],
                "icon": c.get("icon", "star"),
                "image_type": c.get("image_type", "icon"),
                "custom_image": c.get("custom_image"),
                "is_custom": True
            })
    
    return strategies

